# Environment Variables — copy to .env.local

# Laravel API base URL (must include /api — matches routes/api.php prefix)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# When true, login/register/logout use Laravel Sanctum (backend/). When false, local mock auth is used.
NEXT_PUBLIC_USE_LARAVEL_AUTH=false

# When true (with Laravel auth), store/cart/checkout/order-success call Phase 2 marketplace APIs.
NEXT_PUBLIC_USE_LARAVEL_PHASE2=false

# When true (with Laravel auth), subscription catalog, reader access checks, and engagement sync use the API.
NEXT_PUBLIC_USE_LARAVEL_PHASE3=false

# Homepage: try GET /cms/homepage first (Laravel CMS). Set to "0" or "false" to always use the local mock homepage.
NEXT_PUBLIC_CMS_FROM_API=true
