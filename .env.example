# Next.js — copy to `.env.local` for local dev (file is gitignored).
#
# CyberPanel API: https://api.myscriptic.com  ·  PostgreSQL: Laravel `backend/.env` (see backend/.env.example)
# Full checklist: docs/production-api-vercel-cyberpanel.md

# ── Local Next.js (browser at http://localhost:3000) ──────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production API (use while Laravel + Postgres live on CyberPanel)
NEXT_PUBLIC_API_URL=https://api.myscriptic.com/api

# Pure local stack (Laravel + SQLite/Postgres on same machine): use instead of line above
# NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Turn on Laravel integration (required for real API; uses Bearer token from login)
NEXT_PUBLIC_USE_LARAVEL_AUTH=true
NEXT_PUBLIC_USE_LARAVEL_PHASE2=true
NEXT_PUBLIC_USE_LARAVEL_PHASE3=true
NEXT_PUBLIC_USE_LARAVEL_COURSES=true

# Homepage: Laravel CMS when API returns data
NEXT_PUBLIC_CMS_FROM_API=true

# ── Paste into Vercel → Environment Variables (Production + Preview as needed) ─
# NEXT_PUBLIC_SITE_URL=https://myscriptic.vercel.app
# NEXT_PUBLIC_API_URL=https://api.myscriptic.com/api
# NEXT_PUBLIC_USE_LARAVEL_AUTH=true
# NEXT_PUBLIC_USE_LARAVEL_PHASE2=true
# NEXT_PUBLIC_USE_LARAVEL_PHASE3=true
# NEXT_PUBLIC_USE_LARAVEL_COURSES=true
# NEXT_PUBLIC_CMS_FROM_API=true
