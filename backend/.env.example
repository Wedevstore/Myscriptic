APP_NAME=MyScriptic
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Local artisan: http://localhost:8000 — Production (CyberPanel): https://api.myscriptic.com
APP_URL=http://localhost:8000

# Comma-separated Next.js origins (no spaces after commas). Apex, www, and each *.vercel.app host are
# different origins — list every hostname users load the app from. Local dev needs http://localhost:3000.
# Other Vercel preview URLs still match https://*.vercel.app via config/cors.php unless you set
# CORS_USE_VERCEL_PREVIEW_ORIGINS=false below.
CORS_ALLOWED_ORIGINS=https://myscriptic.com,https://www.myscriptic.com,https://myscriptic.vercel.app,http://localhost:3000

# Allow any Origin matching https://*.vercel.app (Laravel allowed_origins_patterns). Set false to require
# every preview URL in CORS_ALLOWED_ORIGINS instead.
CORS_USE_VERCEL_PREVIEW_ORIGINS=true

# SPA URL (password reset links, payment return URLs, Phase 2). Use the URL users actually open.
# Production (match Next canonical + payment return): https://www.myscriptic.com — Vercel-only checkout: https://myscriptic.vercel.app
FRONTEND_URL=http://localhost:3000

# Sanctum SPA hosts (comma-separated, no scheme). Add your production web hostname when you cut over DNS.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,myscriptic.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database: PostgreSQL (CyberPanel production & local Docker) ─────────────
# Local Docker: docker compose -f docker-compose.postgres.yml up -d (see backend/docker-compose.postgres.yml)
# CyberPanel: create DB + user in panel, set password here. Same server: DB_HOST often 127.0.0.1
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=myscriptic
DB_USERNAME=myscriptic
DB_PASSWORD=myscriptic

# Optional: use SQLite only for quick PHP work without Postgres (comment pgsql block above, uncomment below)
# DB_CONNECTION=sqlite
# # DB_DATABASE not needed — uses database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── MyScriptic Phase 2 (marketplace / payments) ─────────────────────────────
ALLOW_MOCK_PAYMENTS=true
DIRECT_SALES_COMMISSION_PCT=20
RATE_NGN=1600
RATE_GHS=15.2
RATE_KES=130

PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
KORAPAY_SECRET_KEY=
PAYPAL_WEBHOOK_ID=

# Phase 3 — subscription revenue pool & engagement
SUBSCRIPTION_POOL_COMMISSION_PCT=30
ENGAGEMENT_MAX_PAGES_PER_MINUTE=5
ENGAGEMENT_MIN_SESSION_SECONDS=30
ENGAGEMENT_MIN_SYNC_INTERVAL_SECONDS=2

# Phase 4 — admin CMS, analytics cache, FCM (legacy HTTP API)
HOMEPAGE_CACHE_TTL=300
ANALYTICS_CACHE_TTL=120
FCM_SERVER_KEY=

# Phase 5 — performance, CDN, ads, logging, Sentry
BOOK_LIST_CACHE_TTL=120
CATEGORIES_CACHE_TTL=600
SEARCH_CACHE_TTL=30
# CACHE_STORE=redis
ASSET_CDN_URL=
ASSET_CDN_SOURCE_HOSTS=

ADS_ENABLED=false
ADS_CLIENT_ID=
ADS_SLOT_BANNER=
ADS_SLOT_FEED=
ADS_SLOT_REWARDED=

LOG_STACK=single,structured
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
