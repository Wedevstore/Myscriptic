APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Comma-separated origins for the Next.js app (see config/cors.php)
CORS_ALLOWED_ORIGINS=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── MyScriptic Phase 2 (marketplace / payments) ─────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOW_MOCK_PAYMENTS=true
DIRECT_SALES_COMMISSION_PCT=20
RATE_NGN=1600
RATE_GHS=15.2
RATE_KES=130

PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
KORAPAY_SECRET_KEY=
PAYPAL_WEBHOOK_ID=

# Phase 3 — subscription revenue pool & engagement
SUBSCRIPTION_POOL_COMMISSION_PCT=30
ENGAGEMENT_MAX_PAGES_PER_MINUTE=5
ENGAGEMENT_MIN_SESSION_SECONDS=30
ENGAGEMENT_MIN_SYNC_INTERVAL_SECONDS=2

# Phase 4 — admin CMS, analytics cache, FCM (legacy HTTP API)
HOMEPAGE_CACHE_TTL=300
ANALYTICS_CACHE_TTL=120
FCM_SERVER_KEY=

# Phase 5 — performance, CDN, ads, logging, Sentry
# For production: CACHE_STORE=redis (see DEPLOYMENT.md)
BOOK_LIST_CACHE_TTL=120
CATEGORIES_CACHE_TTL=600
SEARCH_CACHE_TTL=30
# Uncomment for Redis-backed cache in production:
# CACHE_STORE=redis
ASSET_CDN_URL=
# Comma-separated hostnames that should be rewritten to ASSET_CDN_URL (optional)
ASSET_CDN_SOURCE_HOSTS=

ADS_ENABLED=false
ADS_CLIENT_ID=
ADS_SLOT_BANNER=
ADS_SLOT_FEED=
ADS_SLOT_REWARDED=

LOG_STACK=single,structured
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
